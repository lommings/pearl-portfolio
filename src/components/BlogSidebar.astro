---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

// 按分類分組
const postsByCategory = allPosts.reduce((acc, post) => {
  const category = post.data.category || '未分類';
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof allPosts>);

// 排序分類名稱
const categories = Object.keys(postsByCategory).sort();

// 取得所有標籤並計數
const tagCounts = allPosts.reduce((acc, post) => {
  post.data.tags?.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const sortedTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10); // 只顯示前 10 個熱門標籤

// 當前頁面的 slug（如果有的話）
const currentSlug = Astro.url.pathname.split('/').pop()?.replace('.html', '');
---

<aside class="blog-sidebar">
  <!-- 分類導航 -->
  <nav class="sidebar-section">
    <h3>📂 分類</h3>
    <ul class="category-list">
      {categories.map(category => (
        <li>
          <details open>
            <summary>
              <span class="category-name">{category}</span>
              <span class="post-count">({postsByCategory[category].length})</span>
            </summary>
            <ul class="post-list">
              {postsByCategory[category]
                .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
                .map(post => (
                  <li class={post.slug === currentSlug ? 'active' : ''}>
                    <a href={`/blog/${post.slug}/`}>
                      {post.data.title}
                    </a>
                  </li>
                ))}
            </ul>
          </details>
        </li>
      ))}
    </ul>
  </nav>

  <!-- 熱門標籤 -->
  {sortedTags.length > 0 && (
    <div class="sidebar-section">
      <h3>🏷️ 熱門標籤</h3>
      <div class="tag-cloud">
        {sortedTags.map(([tag, count]) => (
          <a href={`/tags/${tag}/`} class="tag">
            {tag} <span class="tag-count">{count}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- 最新文章 -->
  <div class="sidebar-section">
    <h3>📝 最新文章</h3>
    <ul class="recent-posts">
      {allPosts
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
        .slice(0, 5)
        .map(post => (
          <li class={post.slug === currentSlug ? 'active' : ''}>
            <a href={`/blog/${post.slug}/`}>
              <span class="post-title">{post.data.title}</span>
              <span class="post-date">
                {post.data.pubDate.toLocaleDateString('zh-TW')}
              </span>
            </a>
          </li>
        ))}
    </ul>
  </div>
</aside>

<style>
  .blog-sidebar {
    position: sticky;
    top: 2rem;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    padding: 1.5rem;
    background: rgb(var(--gray-light));
    border-radius: 12px;
  }

  .sidebar-section {
    margin-bottom: 2rem;
  }

  .sidebar-section:last-child {
    margin-bottom: 0;
  }

  .sidebar-section h3 {
    margin: 0 0 1rem 0;
    font-size: 1.1rem;
    color: rgb(var(--gray-dark));
  }

  /* 分類列表 */
  .category-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-list > li {
    margin-bottom: 0.5rem;
  }

  details {
    cursor: pointer;
  }

  summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem;
    border-radius: 6px;
    transition: background 0.2s;
    font-weight: 600;
    color: rgb(var(--gray-dark));
  }

  summary:hover {
    background: rgba(var(--accent), 0.1);
  }

  .post-count {
    font-size: 0.9rem;
    color: rgb(var(--gray));
    font-weight: normal;
  }

  .post-list {
    list-style: none;
    padding: 0.5rem 0 0 1rem;
    margin: 0;
  }

  .post-list li {
    margin-bottom: 0.3rem;
  }

  .post-list a {
    display: block;
    padding: 0.4rem 0.5rem;
    color: rgb(var(--gray));
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .post-list a:hover {
    background: rgba(var(--accent), 0.1);
    color: rgb(var(--accent));
    padding-left: 0.75rem;
  }

  .post-list li.active a {
    background: rgb(var(--accent));
    color: white;
    font-weight: 500;
  }

  /* 標籤雲 */
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.4rem 0.75rem;
    background: white;
    color: rgb(var(--gray-dark));
    text-decoration: none;
    border-radius: 20px;
    font-size: 0.85rem;
    transition: all 0.2s;
    border: 1px solid rgb(var(--gray-light));
  }

  .tag:hover {
    background: rgb(var(--accent));
    color: white;
    border-color: rgb(var(--accent));
    transform: translateY(-2px);
  }

  .tag-count {
    font-size: 0.75rem;
    opacity: 0.7;
  }

  /* 最新文章 */
  .recent-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .recent-posts li {
    margin-bottom: 0.75rem;
  }

  .recent-posts a {
    display: block;
    padding: 0.5rem;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.2s;
  }

  .recent-posts a:hover {
    background: rgba(var(--accent), 0.1);
  }

  .recent-posts li.active a {
    background: rgba(var(--accent), 0.2);
  }

  .post-title {
    display: block;
    color: rgb(var(--gray-dark));
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .post-date {
    display: block;
    color: rgb(var(--gray));
    font-size: 0.75rem;
  }

  /* 滾動條樣式 */
  .blog-sidebar::-webkit-scrollbar {
    width: 6px;
  }

  .blog-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .blog-sidebar::-webkit-scrollbar-thumb {
    background: rgb(var(--gray));
    border-radius: 3px;
  }

  .blog-sidebar::-webkit-scrollbar-thumb:hover {
    background: rgb(var(--gray-dark));
  }

  /* 響應式 */
  @media (max-width: 960px) {
    .blog-sidebar {
      position: static;
      max-height: none;
      margin-bottom: 2rem;
    }
  }

  @media (prefers-color-scheme: dark) {
    .blog-sidebar {
      background: rgb(30, 30, 30);
    }

    .tag {
      background: rgb(40, 40, 40);
      border-color: rgb(50, 50, 50);
    }

    summary:hover {
      background: rgba(var(--accent), 0.2);
    }
  }
</style>
