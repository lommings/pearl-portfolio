---
interface Props {
  src: string;
  title: string;
  width?: string;
  height?: string;
}

const { src, title, width = '100%', height = '600px' } = Astro.props;
---

<div class="game-embed" data-src={src} data-title={title}>
  <div class="game-placeholder">
    <button class="load-game-btn">
      🎮 點擊載入遊戲
    </button>
    <p class="game-title">{title}</p>
  </div>
</div>

<script>
  document.querySelectorAll('.load-game-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const container = this.closest('.game-embed');
      const src = container.dataset.src;
      const title = container.dataset.title;
      
      // 建立 iframe
      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.title = title;
      iframe.frameBorder = '0';
      iframe.allowFullscreen = true;
      iframe.style.width = '100%';
      iframe.style.height = '600px';
      iframe.style.border = 'none';
      iframe.style.borderRadius = '12px';
      
      // 替換佔位符
      container.innerHTML = '';
      container.appendChild(iframe);
      
      // 全螢幕按鈕
      const fullscreenBtn = document.createElement('button');
      fullscreenBtn.textContent = '🔳 全螢幕';
      fullscreenBtn.className = 'fullscreen-btn';
      fullscreenBtn.onclick = () => {
        if (iframe.requestFullscreen) {
          iframe.requestFullscreen();
        } else if (iframe.webkitRequestFullscreen) {
          iframe.webkitRequestFullscreen();
        }
      };
      container.appendChild(fullscreenBtn);
    });
  });
</script>

<style>
  .game-embed {
    margin: 2rem 0;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
  }
  
  .game-placeholder {
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    gap: 1rem;
  }
  
  .load-game-btn {
    padding: 1rem 2rem;
    font-size: 1.25rem;
    background: white;
    color: #667eea;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  
  .load-game-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }
  
  .load-game-btn:active {
    transform: translateY(0);
  }
  
  .game-title {
    font-size: 1.1rem;
    font-weight: 500;
    opacity: 0.9;
  }
  
  .fullscreen-btn {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    padding: 0.5rem 1rem;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: background 0.2s;
  }
  
  .fullscreen-btn:hover {
    background: rgba(0, 0, 0, 0.9);
  }
  
  @media (max-width: 768px) {
    .game-placeholder {
      aspect-ratio: 16/9;
    }
    
    .load-game-btn {
      font-size: 1rem;
      padding: 0.75rem 1.5rem;
    }
  }
</style>
