---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
  heroImage?: any;
}

const { title, description, heroImage } = Astro.props;
---

<html lang="zh-TW">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
      }
      
      .hero-image {
        width: 100%;
        margin-bottom: 2rem;
      }
      
      .hero-image img {
        display: block;
        width: 100%;
        max-height: 400px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
      }
      
      .page-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
        color: rgb(var(--gray-dark));
      }
      
      .page-title {
        text-align: center;
        margin-bottom: 2rem;
      }
      
      .page-title h1 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
      }
      
      .page-content :global(p) {
        line-height: 1.8;
        margin-bottom: 1.5rem;
      }
      
      @media (max-width: 768px) {
        main {
          padding: 1rem;
        }
        
        .page-content {
          padding: 1rem;
        }
        
        .page-title h1 {
          font-size: 2rem;
        }
      }
    </style>
  </head>
  
  <body>
    <Header />
    <main>
      {heroImage && (
        <div class="hero-image">
          <Image width={1200} height={400} src={heroImage} alt="" />
        </div>
      )}
      
      <div class="page-content">
        <div class="page-title">
          <h1>{title}</h1>
        </div>
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
