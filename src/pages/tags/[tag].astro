---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import BlogSidebar from '../../components/BlogSidebar.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const uniqueTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
  
  return uniqueTags.map(tag => ({
    params: { tag },
    props: {
      posts: allPosts
        .filter(post => post.data.tags?.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    }
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<html lang="zh-TW">
  <head>
    <BaseHead title={`標籤: ${tag}`} description={`所有標記為「${tag}」的文章`} />
    <style>
      main {
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2em;
      }
      
      .blog-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 2rem;
        margin-top: 2rem;
      }
      
      .sidebar-wrapper {
        grid-column: 1;
      }
      
      .content-wrapper {
        grid-column: 2;
        min-width: 0;
      }
      
      .tag-header {
        text-align: center;
        margin-bottom: 3rem;
      }
      
      .tag-header h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      
      .tag-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
      }
      
      .post-count {
        color: rgb(var(--gray));
        font-size: 1.1rem;
      }
      
      .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        list-style: none;
        padding: 0;
      }
      
      .post-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      
      .post-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
      }
      
      .post-card a {
        text-decoration: none;
        color: inherit;
      }
      
      .post-image {
        width: 100%;
        height: 200px;
        object-fit: cover;
        background: rgb(var(--gray-light));
      }
      
      .post-content {
        padding: 1.5rem;
      }
      
      .post-title {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: rgb(var(--gray-dark));
      }
      
      .post-description {
        color: rgb(var(--gray));
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1rem;
      }
      
      .post-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        color: rgb(var(--gray));
      }
      
      .category-badge {
        padding: 0.25rem 0.75rem;
        background: rgb(var(--accent));
        color: white;
        border-radius: 12px;
        font-size: 0.8rem;
      }
      
      /* 響應式設計 */
      @media (max-width: 960px) {
        .blog-container {
          grid-template-columns: 1fr;
        }
        
        .sidebar-wrapper {
          grid-column: 1;
          grid-row: 1;
        }
        
        .content-wrapper {
          grid-column: 1;
          grid-row: 2;
        }
        
        main {
          padding: 0 1em;
        }
      }
      
      @media (max-width: 640px) {
        .posts-grid {
          grid-template-columns: 1fr;
        }
        
        .tag-header h1 {
          font-size: 2rem;
        }
      }
      
      @media (prefers-color-scheme: dark) {
        .post-card {
          background: rgb(30, 30, 30);
        }
      }
    </style>
  </head>
  
  <body>
    <Header />
    <main>
      <div class="blog-container">
        <!-- 左側邊欄 -->
        <div class="sidebar-wrapper">
          <BlogSidebar />
        </div>
        
        <!-- 右側內容 -->
        <div class="content-wrapper">
          <div class="tag-header">
            <div class="tag-icon">🏷️</div>
            <h1>#{tag}</h1>
            <p class="post-count">共 {posts.length} 篇文章</p>
          </div>
          
          <ul class="posts-grid">
            {posts.map(post => (
              <li class="post-card">
                <a href={`/blog/${post.id}/`}>
                  {post.data.heroImage && (
                    <img src={post.data.heroImage.src} alt="" class="post-image" />
                  )}
                  <div class="post-content">
                    <h2 class="post-title">{post.data.title}</h2>
                    <p class="post-description">{post.data.description}</p>
                    <div class="post-meta">
                      <span class="post-date">
                        <FormattedDate date={post.data.pubDate} />
                      </span>
                      {post.data.category && (
                        <span class="category-badge">{post.data.category}</span>
                      )}
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
