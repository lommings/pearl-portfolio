---
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import Layout from '../layouts/Page.astro';
---

<Layout
	title="關於我"
	description="更多關於 Lizzy Amano 的資訊"
	heroImage={AboutHeroImage}
>
	<h1 style="text-align: center; margin-bottom: 2rem;">關於 Lizzy Amano</h1>
	
	<p style="font-size: 1.1em; line-height: 1.8; text-align: center; margin-bottom: 2rem;">
		用文字傳遞愛與感動，歡迎同好來交流 ✨
	</p>
	
	<hr style="border: none; border-top: 1px solid #e0e0e0; margin: 2rem 0;">
	
	<h2>📱 創作平台</h2>
	
	<p style="line-height: 2; font-size: 1.05em;">
		📝 <strong>Lofter</strong> <a href="https://a-lise.lofter.com/" target="_blank" style="color: #3B5998; text-decoration: none; border-bottom: 2px solid #3B5998;">山風為嵐</a><br>
		🔗 <strong>AO3</strong> <a href="https://archiveofourown.org/users/ArashiStorm" target="_blank" style="color: #900; text-decoration: none; border-bottom: 2px solid #900;">ArashiStorm</a>
	</p>
	
	<hr style="border: none; border-top: 1px solid #e0e0e0; margin: 2rem 0;">
	
	<h2>💙 關於我</h2>
	
	<p style="line-height: 2; font-size: 1.05em;">
		<strong>本命</strong> 大野智
	</p>
	
	<p style="line-height: 1.8; color: #555;">
		天然、模特、JS<br>
		雜食，隨緣產糧。<br>
		已寫 cp：山組、竹馬、天然
	</p>
	
	<hr style="border: none; border-top: 1px solid #e0e0e0; margin: 2rem 0;">
	
	<p style="text-align: center; font-size: 2rem; letter-spacing: 0.5rem; margin: 3rem 0;">
		💙 ❤️ 💚 💛 💜
	</p>
	
	<p style="text-align: center; color: #999; font-size: 0.9em;">
		ARASHI forever ✨
	</p>
</Layout>
